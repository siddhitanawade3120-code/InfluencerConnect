generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BRAND
  CREATOR
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  role         UserRole
  name         String
  phone        String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  brandProfile   BrandProfile?
  creatorProfile CreatorProfile?
}

model BrandProfile {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  userId       String  @unique @db.ObjectId
  user         User    @relation(fields: [userId], references: [id])
  businessName String
  category     String
  budgetMin    Int
  budgetMax    Int
  area         String
  city         String  @default("Vasai-Virar")
  logoUrl      String?
  website      String?
}

model CreatorProfile {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  userId          String  @unique @db.ObjectId
  user            User    @relation(fields: [userId], references: [id])
  instagramHandle String  @unique
  bio             String?
  /// Optional link to admin-added Creator record (claimed profile)
  creatorId       String? @unique @db.ObjectId
}

model Creator {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  instagramHandle        String   @unique
  fullName               String
  city                   String
  area                   String
  nicheTags              String
  followerCount          Int
  avgEngagementRate      Float
  estimatedRateMin       Int
  estimatedRateMax       Int
  contactMethod          String
  contactValue           String
  lastVerifiedDate       DateTime
  profilePicUrl          String
  accountType            String
  isVerifiedActive       Boolean  @default(true)
  recentPostCountChecked Int?
  avgLikes               Int?
  avgComments            Int?
  contentStyle           String?
  previousBrandCollabs   String?
  language               String?
  sourceFound            String?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Inquiry {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  brandId       String    @db.ObjectId
  creatorId     String    @db.ObjectId
  status        String    @default("PENDING")
  offeredBudget Int
  deliverables  String
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  messages      Message[]
}

model Message {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  inquiryId  String   @db.ObjectId
  inquiry    Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  senderRole String
  senderId   String   @db.ObjectId
  body       String
  createdAt  DateTime @default(now())
}
